@page
@model Web.Pages.Vehiculos.EliminarModel
@{
}
<h1>Eliminar Vehiculo</h1>

<div class="container">
	<form method="post">
	<div class="col-md-8">
		<div class="card">
			<div class="card-body">
				<h5 class="card-title">@Html.DisplayFor(modelo => modelo.vehiculo.Marca) @Html.DisplayFor(modelo => modelo.vehiculo.Modelo)</h5>
				<p class="card-text">
					<div>
						<b>@Html.DisplayNameFor(modelo => modelo.vehiculo.Placa):</b>
						@Html.DisplayNameFor(modelo => modelo.vehiculo.Placa)
					</div>
					<div>
						<b>@Html.DisplayNameFor(modelo => modelo.vehiculo.Anio):</b>
						@Html.DisplayNameFor(modelo => modelo.vehiculo.Anio)
					</div>
					<div>
						<b>@Html.DisplayNameFor(modelo => modelo.vehiculo.Precio):</b>
						@Html.DisplayNameFor(modelo => modelo.vehiculo.Precio)
					</div>
				</p>
				<p class="card-text">
					<small class="texto-muted">@Html.DisplayFor(modelo => modelo.vehiculo.CorreoPropietario) | @Html.DisplayFor(modelo => modelo.vehiculo.TelefonoPropietario)</small>
				</p>


				<div />
				<div />
				<div />
				<a type="button" class="btn btn-primary" asp-page="./Index">Regresar</a>
				<button type="submit" class="btn btn-danger">Eliminar</button>
		     </form>
				<div />
